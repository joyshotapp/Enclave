# ══════════════════════════════════════════
#  Enclave — 企業私有 AI 知識大腦
#  環境設定範本（複製為 .env 後修改）
# ══════════════════════════════════════════

# ── 基本設定 ──
APP_NAME=Enclave
ORGANIZATION_NAME=我的組織
APP_ENV=production
API_V1_STR=/api/v1
# 請使用強隨機字串（至少 32 字元），可執行 python scripts/dev/gen_hash.py 產生
SECRET_KEY=change_this_to_a_secure_random_string_at_least_32_chars
FIRST_SUPERUSER_EMAIL=admin@enclave.local
FIRST_SUPERUSER_PASSWORD=請立即修改此密碼

# ── LLM 設定（三選一）──
# 選項 A：Google Gemini（推薦，性價比高）
LLM_PROVIDER=gemini
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-3-flash-preview
# 選項 B：OpenAI API
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# 選項 C：Ollama 本機 LLM（零 API 費用，需要較強硬體）
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://host.docker.internal:11434
# OLLAMA_MODEL=llama3.2

# ── 向量嵌入設定 ──
VOYAGE_API_KEY=voyage-...
VOYAGE_MODEL=voyage-4-lite

# ── 文件解析設定 ──
LLAMAPARSE_ENABLED=true
LLAMAPARSE_API_KEY=
LLAMAPARSE_LANGUAGE=zh-TW
OCR_LANGS=chi_tra+eng

# ── 資料庫（PostgreSQL）──
POSTGRES_SERVER=db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=請修改此密碼
POSTGRES_DB=enclave

# ── Redis（任務佇列）──
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Phase 10: Agent 自動索引 ──
AGENT_WATCH_ENABLED=false
# 多個資料夾以半形逗號分隔（容器內路徑）
AGENT_WATCH_FOLDERS=
AGENT_BATCH_HOUR=2
AGENT_MAX_CPU_PERCENT=50.0

# ── Phase 11: 內容生成 ──
GENERATION_MAX_TOKENS=3000
